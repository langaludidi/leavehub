# Production Environment Variables for Vercel Deployment
# Copy this to .env.local and fill in your actual values

# Supabase Configuration (Required)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Calendar Integration (Optional - for calendar sync)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
VITE_GOOGLE_API_KEY=your_google_api_key_here

# Microsoft Outlook Integration (Optional - for calendar sync)  
VITE_OUTLOOK_CLIENT_ID=your_microsoft_app_client_id_here

# Stripe Configuration (Optional - for billing features)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key_here

# App Configuration
VITE_APP_URL=https://your-app.vercel.app